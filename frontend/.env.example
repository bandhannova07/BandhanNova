# BandhanNova Frontend Environment Variables

# API Configuration
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_API_VERSION=v1

# Google Services
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# Payment Integration
REACT_APP_GOOGLE_PAY_MERCHANT_ID=your_google_pay_merchant_id_here

# App Configuration
REACT_APP_APP_NAME=BandhanNova
REACT_APP_APP_VERSION=1.0.0
REACT_APP_SUPPORT_EMAIL=support@bandhannova.com
REACT_APP_ADMIN_EMAIL=admin@bandhannova.com

# Feature Flags
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_PWA=true
REACT_APP_ENABLE_ANALYTICS=true

# Development
REACT_APP_DEBUG_MODE=false
REACT_APP_LOG_LEVEL=info
